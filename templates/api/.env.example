# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB connection string — required for Prisma to run prisma generate
DATABASE_URL=mongodb://localhost:27017/your-db-name

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-secret
JWT_REFRESH_SECRET=replace-with-a-different-strong-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# ─── Redis (optional) ────────────────────────────────────────────────────────
# Required only if your app uses caching, rate limiting, or session storage
# REDIS_URL=redis://localhost:6379

# ─── Cloudinary (optional) ───────────────────────────────────────────────────
# Required only if your app supports file or image uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── Logging (optional) ──────────────────────────────────────────────────────
# Required only if using Logtail / BetterStack for log ingestion
# LOGTAIL_SOURCE_TOKEN=
